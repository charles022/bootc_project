# Use Fedora bootc as the host operating system image.
FROM quay.io/fedora/fedora-bootc:42

# Install only the host packages we actually need.
# cloud-init is included so downstream users can inject their own SSH key
# via a NoCloud seed at first boot, without rebuilding the OCI image.
RUN dnf -y install 'dnf5-command(config-manager)' \
    && dnf config-manager addrepo --from-repofile=https://developer.download.nvidia.com/compute/cuda/repos/fedora42/x86_64/cuda-fedora42.repo \
    && dnf -y install \
       openssh-server \
       podman \
       skopeo \
       nvidia-open \
       nvidia-container-toolkit \
       cloud-init \
       bash \
       coreutils \
       passt \
       shadow-utils \
       systemd-container \
       gettext \
       jq \
       python3 \
       python3-cryptography \
    && dnf clean all

# Create only the directories we need in the host image.
RUN mkdir -p /usr/share/containers/systemd \
    && mkdir -p /usr/lib/systemd/system \
    && mkdir -p /opt/project

# Copy the host startup test and its systemd unit into the image.
COPY bootc_host_test.sh /opt/project/bootc_host_test.sh
COPY bootc-host-test.service /usr/lib/systemd/system/bootc-host-test.service
COPY nvidia-cdi-refresh.service /usr/lib/systemd/system/nvidia-cdi-refresh.service
COPY nvidia-cdi-refresh.path /usr/lib/systemd/system/nvidia-cdi-refresh.path

# Copy the scheduled-update orchestrator and its first-boot push companion.
# bootc-update.timer fires bootc-update.service on a weekly cadence; the
# service runs an ephemeral os-builder container that produces a fresh
# host image and stages it via `bootc switch --transport oci-archive`.
# bootc-firstboot-push.service runs once on the first boot of every
# freshly-staged deployment and conditionally publishes the booted image
# to Quay if /etc/bootc-update/reboot.env requests it.
COPY bootc-update.service /usr/lib/systemd/system/bootc-update.service
COPY bootc-update.timer /usr/lib/systemd/system/bootc-update.timer
COPY bootc-update.sh /usr/local/bin/bootc-update.sh
COPY bootc-firstboot-push.service /usr/lib/systemd/system/bootc-firstboot-push.service
COPY bootc-firstboot-push.sh /usr/local/bin/bootc-firstboot-push.sh
COPY bootc-update-nudge.sh /etc/profile.d/bootc-update-nudge.sh
RUN chmod 0755 /usr/local/bin/bootc-update.sh /usr/local/bin/bootc-firstboot-push.sh \
    && chmod 0644 /etc/profile.d/bootc-update-nudge.sh

# Setup Console Autologin for easy VM console access (no network required).
# This is the fallback path — useful for recovery when SSH isn't reachable.
# It does not compromise published images because console access requires
# physical/virtual console, not network.
RUN mkdir -p /etc/systemd/system/getty@tty1.service.d/
COPY autologin.conf /etc/systemd/system/getty@tty1.service.d/override.conf

# Make the host startup test executable.
RUN chmod 0755 /opt/project/bootc_host_test.sh

# Copy the Quadlet files that define the pod-managed containers.
COPY devpod.kube /usr/share/containers/systemd/devpod.kube
COPY devpod.yaml /usr/share/containers/systemd/devpod.yaml

# Copy the host-managed backup Quadlet and its activation timer.
COPY backup.container /usr/share/containers/systemd/backup.container
COPY backup.timer /usr/lib/systemd/system/backup.timer

# --- Multi-tenant layer (additive) ---
# See docs/concepts/multi_tenant_architecture.md for the design.
# The host ships:
#   - platformctl admin CLI
#   - openclaw-broker daemon (Phase 2: encrypted credential store, grants,
#     audit, admin + per-tenant sockets)
#   - openclaw-provisioner daemon (Phase 3: agent self-provisioning; reads
#     per-tenant policy YAML, validates requests, renders agent Quadlets,
#     drives systemd; admin + per-tenant sockets)
#   - per-tenant Quadlet templates rendered by `platformctl tenant create`
#   - per-agent Quadlet templates rendered by openclaw-provisioner on each
#     agent_create call
#   - the /var/lib/openclaw-platform tree skeleton (per-tenant subtrees are
#     created on demand)
COPY multi_tenant/platformctl.sh /usr/local/bin/platformctl
COPY multi_tenant/openclaw-broker.py /usr/local/bin/openclaw-broker
COPY multi_tenant/openclaw-broker.service /usr/lib/systemd/system/openclaw-broker.service
COPY multi_tenant/openclaw-provisioner.py /usr/local/bin/openclaw-provisioner
COPY multi_tenant/openclaw-provisioner.service /usr/lib/systemd/system/openclaw-provisioner.service
RUN chmod 0755 /usr/local/bin/platformctl /usr/local/bin/openclaw-broker /usr/local/bin/openclaw-provisioner

# Install the Quadlet templates into the platform template root.
# - templates/quadlet/         tenant onboarding pod, rendered by `platformctl tenant create`
# - templates/agent_quadlet/   agent pods, rendered by openclaw-provisioner on each agent_create
RUN install -d -m 0755 \
        /var/lib/openclaw-platform \
        /var/lib/openclaw-platform/templates \
        /var/lib/openclaw-platform/templates/quadlet \
        /var/lib/openclaw-platform/templates/agent_quadlet \
        /var/lib/openclaw-platform/broker \
        /var/lib/openclaw-platform/provisioner \
        /var/lib/openclaw-platform/backups \
        /var/lib/openclaw-platform/tenants \
        /etc/containers/systemd/users
COPY multi_tenant/tenant-onboard.pod.tmpl                 /var/lib/openclaw-platform/templates/quadlet/tenant-onboard.pod.tmpl
COPY multi_tenant/tenant-cloudflared.container.tmpl       /var/lib/openclaw-platform/templates/quadlet/tenant-cloudflared.container.tmpl
COPY multi_tenant/tenant-onboard-env.container.tmpl       /var/lib/openclaw-platform/templates/quadlet/tenant-onboard-env.container.tmpl
COPY multi_tenant/tenant-openclaw-runtime.container.tmpl  /var/lib/openclaw-platform/templates/quadlet/tenant-openclaw-runtime.container.tmpl
COPY multi_tenant/tenant-credential-proxy.container.tmpl  /var/lib/openclaw-platform/templates/quadlet/tenant-credential-proxy.container.tmpl
COPY multi_tenant/agent_quadlet/agent.pod.tmpl                       /var/lib/openclaw-platform/templates/agent_quadlet/agent.pod.tmpl
COPY multi_tenant/agent_quadlet/agent-openclaw-runtime.container.tmpl /var/lib/openclaw-platform/templates/agent_quadlet/agent-openclaw-runtime.container.tmpl
COPY multi_tenant/agent_quadlet/agent-dev-env.container.tmpl         /var/lib/openclaw-platform/templates/agent_quadlet/agent-dev-env.container.tmpl
COPY multi_tenant/agent_quadlet/agent-credential-proxy.container.tmpl /var/lib/openclaw-platform/templates/agent_quadlet/agent-credential-proxy.container.tmpl
COPY multi_tenant/agent_quadlet/agent-cloudflared.container.tmpl     /var/lib/openclaw-platform/templates/agent_quadlet/agent-cloudflared.container.tmpl
# Phase 4 messaging-bridge sidecar templates. The provisioner only renders
# the ones whose transport is in the agent's --messaging request list.
COPY multi_tenant/agent_quadlet/agent-messaging-bridge-email.container.tmpl    /var/lib/openclaw-platform/templates/agent_quadlet/agent-messaging-bridge-email.container.tmpl
COPY multi_tenant/agent_quadlet/agent-messaging-bridge-signal.container.tmpl   /var/lib/openclaw-platform/templates/agent_quadlet/agent-messaging-bridge-signal.container.tmpl
COPY multi_tenant/agent_quadlet/agent-messaging-bridge-whatsapp.container.tmpl /var/lib/openclaw-platform/templates/agent_quadlet/agent-messaging-bridge-whatsapp.container.tmpl
RUN chmod 0644 /var/lib/openclaw-platform/templates/quadlet/*.tmpl \
            /var/lib/openclaw-platform/templates/agent_quadlet/*.tmpl

# Seed the bootc-update config: source.env in /etc so it survives upgrades
# with a 3-way merge (operator can repoint to a fork); reboot.env in /etc
# for the same reason; /var/lib/bootc-update for the staging marker (lives
# in /var so it persists across the stage-but-not-yet-rebooted window).
RUN mkdir -p /etc/bootc-update /var/lib/bootc-update \
    && printf '%s\n' \
        '# Upstream source the os-builder clones for each scheduled rebuild.' \
        '# Repoint to a fork by editing this file; survives bootc upgrades.' \
        'SOURCE_REPO=https://github.com/charles022/bootc_project.git' \
        'SOURCE_BRANCH=main' \
        > /etc/bootc-update/source.env \
    && printf '%s\n' \
        '# Set push_to_quay=TRUE before rebooting into a freshly-staged image' \
        '# to publish it to Quay on its first successful boot. The push runs' \
        '# once and the flag is cleared back to FALSE automatically.' \
        'push_to_quay=FALSE' \
        > /etc/bootc-update/reboot.env

# Enable the host-native services that should start on boot.
# cloud-init.target pulls in the four cloud-init stages so a NoCloud seed
# (or bootc-image-builder-injected config) is consumed on first boot.
RUN systemctl enable sshd \
    && systemctl enable cloud-init.target \
    && systemctl enable bootc-host-test.service \
    && systemctl enable nvidia-cdi-refresh.path \
    && systemctl enable nvidia-cdi-refresh.service \
    && systemctl enable bootc-update.timer \
    && systemctl enable bootc-firstboot-push.service \
    && systemctl enable openclaw-broker.service \
    && systemctl enable openclaw-provisioner.service \
    && systemctl enable backup.timer
