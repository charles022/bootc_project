# Credential proxy sidecar for an OpenClaw tenant pod.
# Platform-controlled: pod-local UNIX socket interface, no broad mounts.
# Phase-0 image is a stub. Phase-2 implements the real broker client.
[Unit]
Description=OpenClaw credential proxy for tenant ${TENANT}
After=${TENANT}-onboard-pod.service
BindsTo=${TENANT}-onboard-pod.service

[Container]
Image=quay.io/m0ranmcharles/fedora_init:credential-proxy
Pod=${TENANT}-onboard.pod
Environment=OPENCLAW_TENANT=${TENANT}
ReadOnly=true
NoNewPrivileges=true

[Service]
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
