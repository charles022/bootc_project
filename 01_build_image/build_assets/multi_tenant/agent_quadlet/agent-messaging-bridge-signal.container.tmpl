# Signal messaging-bridge sidecar for agent ${TENANT}/${AGENT}.
# Rendered only when --messaging signal is included in the agent_create request.
# See docs/concepts/messaging_interface.md.
[Unit]
Description=Messaging bridge (signal) ${TENANT}/${AGENT}
After=${TENANT}-${AGENT}-pod.service
BindsTo=${TENANT}-${AGENT}-pod.service

[Container]
Image=quay.io/m0ranmcharles/fedora_init:messaging-bridge-signal
Pod=${TENANT}-${AGENT}.pod
Environment=OPENCLAW_TENANT=${TENANT}
Environment=OPENCLAW_AGENT=${AGENT}
Environment=OPENCLAW_BROKER_SOCKET=/run/credential-proxy/broker.sock
Environment=OPENCLAW_MSGBUS_INBOUND=/run/messaging-bridge/inbound.sock
Environment=OPENCLAW_MSGBUS_OUTBOUND=/run/messaging-bridge/outbound-signal.sock
Environment=OPENCLAW_SIGNAL_CREDENTIAL=signal
Volume=/run/openclaw-broker/tenants/${TENANT}.sock:/run/credential-proxy/broker.sock:ro,Z
Volume=${TENANT_HOME}/agents/${AGENT}/msgbus:/run/messaging-bridge:Z
NoNewPrivileges=true

[Service]
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=default.target
